# ==========================================
# 1. 通用/IDE 配置
# ==========================================
.idea/
.vscode/
*.swp
*.bak
*.tmp
.DS_Store
Thumbs.db

# ==========================================
# 2. 后端配置 (Java/Maven/Spring Boot)
# ==========================================
# 编译后的类文件
todotodo-backend/**/*.class
todotodo-backend/**/target/
todotodo-backend/**/bin/

# 日志文件
todotodo-backend/**/logs/
todotodo-backend/**/*.log

# Maven 属性文件
todotodo-backend/.mvn/wrapper/maven-wrapper.jar
todotodo-backend/release.properties
todotodo-backend/pom.xml.tag
todotodo-backend/pom.xml.releaseBackup
todotodo-backend/pom.xml.backup
todotodo-backend/pom.xml.versionsBackup

# Gradle 缓存
todotodo-backend/.gradle/
todotodo-backend/build/

# ==========================================
# 3. 前端配置 (Node/Angular)
# ==========================================
# 依赖
todotodo-frontend/node_modules/
todotodo-frontend/todotodo-frontend/dist/
todotodo-frontend/.angular/
node_modules/
# 日志与缓存
todotodo-frontend/npm-debug.log*
todotodo-frontend/yarn-debug.log*
todotodo-frontend/yarn-error.log*
todotodo-frontend/.eslintcache
todotodo-frontend/.cache/

# 单元测试与覆盖率
todotodo-frontend/coverage/
todotodo-frontend/.nyc_output/

# 环境变量 (包含敏感信息)
todotodo-frontend/.env
todotodo-frontend/.env.*
!todotodo-frontend/.env.example

# ==========================================
# 4. 其他 (构建产物)
# ==========================================
# 如果有打包后的产物
*.jar
*.war
*.zip
*.tar.gz
